APP_NAME="Shipping Gateway"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Riyadh

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── MySQL ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cbex
DB_USERNAME=root
DB_PASSWORD=

# Queue
QUEUE_CONNECTION=redis

CACHE_DRIVER=file
CACHE_PREFIX=sg_cache_

SESSION_DRIVER=file
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=shipping-gateway

# ── Payment — Moyasar ─────────────────────────────────
MOYASAR_API_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_TEST_KEY=
MOYASAR_TEST_SECRET=
MOYASAR_LIVE_MODE=false

# ── FedEx ─────────────────────────────────────────────
FEDEX_DEFAULT_CARRIER=fedex
FEDEX_BASE_URL=https://apis-sandbox.fedex.com
FEDEX_OAUTH_URL=https://apis-sandbox.fedex.com/oauth/token
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_SHIPPER_ACCOUNT=
FEDEX_BILL_TO_ACCOUNT=

# ── Shopify ───────────────────────────────────────────
SHOPIFY_API_VERSION=2024-01
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── VAT ───────────────────────────────────────────────
VAT_RATE=15.00

# ── Feature Flags ─────────────────────────────────────
FEATURE_PAYMENT_MOYASAR=false
FEATURE_PAYMENT_STRIPE=false
FEATURE_PAYMENT_STCPAY=false
FEATURE_CARRIER_ARAMEX=false
FEATURE_CARRIER_DHL=false
FEATURE_CARRIER_FEDEX=false
FEATURE_CARRIER_FEDEX_TRACKING=false
FEATURE_CARRIER_SMSA=false
FEATURE_CARRIER_JNT=false
FEATURE_PLATFORM_SHOPIFY=false
FEATURE_PLATFORM_SALLA=false
FEATURE_PLATFORM_ZID=false
FEATURE_PLATFORM_WOOCOMMERCE=false
FEATURE_AI_DELAY_PREDICTION=false
FEATURE_DYNAMIC_PRICING=false
FEATURE_MULTI_MODAL_ROUTING=false
FEATURE_SANDBOX_MODE=true
FEATURE_DEMO_DATA=false
